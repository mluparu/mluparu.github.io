---
import { type CollectionEntry } from 'astro:content';
import ArrowRight from '../assets/icons/arrow-right.svg';
import FormattedDate from './FormattedDate.astro';
import CustomImage from './CustomImage.astro';

type Props = { post: CollectionEntry<'blog'>; class?: string; headingLevel?: 'h2' | 'h3' };

const { post, class: className, headingLevel = 'h2' } = Astro.props;
const { title, publishDate, updatedDate, excerpt, seo } = post.data;
const TitleTag = headingLevel;
---

<a class:list={['group flex flex-col sm:flex-row items-start gap-6 sm:gap-8', className]} href={`/blog/${post.id}/`}>
    {
        seo?.image?.src && (
            <div class="w-full shrink-0 overflow-hidden rounded-lg sm:w-48 lg:w-64">
                <CustomImage
                    class="aspect-video w-full object-cover transition duration-500 group-hover:scale-105"
                    {...seo.image}
                    width={400}
                    height={225}
                    widths={[400, 800]}
                    sizes="(max-width: 640px) 100vw, 256px"
                />
            </div>
        )
    }
    <div class="grow">
        <div class="mt-1 text-sm leading-normal">
            📅 <FormattedDate date={publishDate} />
            {
                updatedDate && (
                    <>
                        {' '}
                        <span>
                            (Updated on <FormattedDate date={updatedDate} />)
                        </span>
                    </>
                )
            }
        </div>
        <TitleTag
            class="mt-2 font-serif text-xl leading-tight font-medium group-hover:underline group-hover:decoration-dashed group-hover:decoration-1 group-hover:underline-offset-4 sm:text-2xl"
        >
            {title}
        </TitleTag>
        {excerpt && <div class="mt-3 text-sm leading-normal line-clamp-2">{excerpt}</div>}
        <div class="mt-4 flex font-serif italic sm:items-center sm:gap-1 text-sm opacity-0 transition-opacity group-hover:opacity-100">
            Read Post <ArrowRight class="h-4 w-4 fill-current ml-1" />
        </div>
    </div>
</a>
